flowchart TD
    U["<b>YOU</b><br/>Write your request naturally"]
    U --> L1

    subgraph BEFORE["Before AI works"]
        L1["<b>Layer 1 — CLAUDE.md</b><br/>Baseline: conventions, stack, security rules"]
        L2["<b>Layer 2 — SessionStart</b><br/>Reloads project memory, backlog, decisions"]
        L3["<b>Layer 3 — THE GUARDIAN</b><br/>Classifies prompt: fix / feature / refactor / question<br/>Injects mandatory pipeline"]
        L1 --> L2 --> L3
    end

    L3 --> AI["<b>AI WORKS</b><br/>With forced quality pipeline:<br/>TDD, debugging, proofs, review"]

    subgraph DURING["While AI works"]
        L4["<b>Layer 4 — PreToolUse</b><br/>Blocks: secrets, .env,<br/>force push, SQL injection"]
        L5["<b>Layer 5 — PostToolUse</b><br/>Auto-format, lint,<br/>security scan, tracking"]
    end

    AI --> L4
    AI --> L5

    AI --> L6

    subgraph AFTER["Before session ends"]
        L6["<b>Layer 6 — THE LOCK</b><br/>Blocks if: tests missing,<br/>proofs unsatisfied,<br/>capitalization skipped"]
    end

    L6 -->|"All gates pass"| DONE["<b>Session complete</b><br/>Memory saved for next session"]
    L6 -->|"Gate fails"| AI

